# MotherDuck API base. Defaults to production in code; override for staging.
MOTHERDUCK_API_URL=https://api.motherduck.com

# Public origin of THIS app — used to build the OAuth callback URL.
# Must match a redirect URI the OAuth client is registered with.
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign/encrypt the short-lived Dive-query capability tokens
# (the AES-256-GCM key is derived from it). NOT a MotherDuck credential —
# generate a random value, e.g.  openssl rand -base64 32  — and keep it stable
# across instances/deploys. Required to view Dives.
DIVE_QUERY_SECRET=
