# MotherDuck API base. Defaults to production in code; override for staging.
MOTHERDUCK_API_URL=https://api.motherduck.com

# Public origin of THIS app — used to build the OAuth callback URL.
# Must match a redirect URI the OAuth client is registered with.
NEXTAUTH_URL=http://localhost:3000

# MotherDuck service-account (Admin) token, used SERVER-SIDE to mint Dive
# embed sessions (POST /v1/dives/{id}/embed-session). The embed endpoint only
# accepts a service-account token — never the end user's delegated token — so
# this is required to view Dives. The app runs each embed as the signed-in
# user (via the `username` param), so users see their own data. Create one in
# the MotherDuck UI (Settings → Service accounts). Without it, the Dive list
# still works but opening a Dive shows a "not configured" notice.
MOTHERDUCK_EMBED_TOKEN=

# Optional: override the embed sandbox host (defaults to embed-motherduck.com).
# DIVE_EMBED_HOST=https://embed-motherduck.com
